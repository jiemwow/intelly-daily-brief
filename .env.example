OPENAI_API_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL="Daily Brief <onboarding@resend.dev>"
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL="Daily Brief <sender@example.com>"
WECHAT_BRIDGE_URL=
IM_BRIDGE_URL=
BRIEF_RECIPIENT_EMAIL=jiem.yangjie@huawei.com
BRIEF_TIMEZONE=Asia/Shanghai
CRON_SECRET=
APP_URL=http://localhost:3000
APP_BASE_URL=http://localhost:3000
PUSH_SCHEDULE_WINDOW_MINUTES=15
OPENAI_MODEL=gpt-5.4
# The dispatch logic supports a rolling time window. On Vercel Hobby, the bundled cron
# runs once per day at 08:00 China time; use a finer external scheduler if you need
# per-user minute-level delivery windows.
# For real email delivery, set either Resend or SMTP.
# For WeChat / IM push, point WECHAT_BRIDGE_URL or IM_BRIDGE_URL to your bridge webhook.
